ENV=development
PORT=3001

# PostgreSQL (matches docker-compose.dev.yml)
DATABASE_URL=postgresql+asyncpg://medrush:medrush_dev@localhost:5432/medrush_core

# Redis (matches docker-compose.dev.yml)
REDIS_URL=redis://localhost:6379

# Kafka (disabled by default — no broker needed)
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092

# Payments (stub mode — no real Razorpay calls)
ENABLE_PAYMENT_GATEWAY=false
RAZORPAY_KEY_ID=rzp_test_placeholder
RAZORPAY_KEY_SECRET=rzp_secret_placeholder

# S3 / Rx images (stub mode — presigned URLs are mocked)
S3_BUCKET_RX=medrush-rx-vault
S3_REGION=ap-south-1

# CORS — allow frontend + pharmacy dashboard
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Feature flags
ENABLE_RX_VERIFICATION=false
IDEMPOTENCY_TTL=86400
